{
    "name": "flapjackhq/flapjack-search-laravel-scout",
    "description": "Flapjack Search driver for Laravel Scout",
    "license": "MIT",
    "type": "library",
    "keywords": ["flapjack", "search", "laravel", "scout", "full-text-search"],
    "require": {
        "php": "^8.1",
        "laravel/scout": "^10.0|^11.0",
        "flapjackhq/flapjack-search-php": "dev-main"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Flapjack\\Scout\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Flapjack\\Scout\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Flapjack\\Scout\\FlapjackScoutServiceProvider"
            ]
        }
    },
    "config": {
        "platform": {
            "php": "8.1"
        }
    },
    "minimum-stability": "beta",
    "prefer-stable": true
}

# Copy to /etc/flapjack/env when using EnvironmentFile in flapjack.service.
# Full env var inventory/defaults: ../../docs2/3_IMPLEMENTATION/OPS_CONFIGURATION.md

# Production-essential values
FLAPJACK_DATA_DIR=/opt/flapjack/data
FLAPJACK_BIND_ADDR=0.0.0.0:7700
FLAPJACK_ENV=production
FLAPJACK_ADMIN_KEY=replace-with-strong-admin-key
FLAPJACK_LOG_FORMAT=json
RUST_LOG=info

# Optional SSL
# FLAPJACK_SSL_EMAIL=admin@example.com
# FLAPJACK_PUBLIC_IP=203.0.113.10
# FLAPJACK_ACME_DIRECTORY=https://acme-v02.api.letsencrypt.org/directory

# Optional S3 snapshots
# FLAPJACK_S3_BUCKET=flapjack-snapshots-prod
# FLAPJACK_S3_REGION=us-west-1
# FLAPJACK_S3_ENDPOINT=
# FLAPJACK_SNAPSHOT_INTERVAL=300

# Optional replication
# FLAPJACK_NODE_ID=node-a
# FLAPJACK_PEERS=node-b=http://10.0.1.2:7700,node-c=http://10.0.1.3:7700
# FLAPJACK_SYNC_INTERVAL_SECS=60
# FLAPJACK_STARTUP_CATCHUP_TIMEOUT_SECS=30
